PORT=11000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=stocks

# Upstox auto-sync (set these when you share your key/token)
ENABLE_UPSTOX_SYNC=true
UPSTOX_BASE_URL=https://api.upstox.com/v3
# For analytics token (read-only access), set UPSTOX_ACCESS_TOKEN to your analytics token
# Get analytics token from: https://upstox.com/developer/api-documentation/analytics-token
UPSTOX_ACCESS_TOKEN=your_upstox_analytics_token_here

# Instrument format helper:
# false => uses PREFIX + symbol (example: NSE_EQ|RELIANCE)
# true  => uses symbol as direct instrument key from DB
UPSTOX_INSTRUMENT_DIRECT=false
UPSTOX_INSTRUMENT_PREFIX=NSE_EQ|
